# ─────────────────────────────────────────────────────────────
# Cafe POS — environment template (PRD §17)
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# ─────────────────────────────────────────────────────────────

# ---- Postgres (consumed by docker-compose.yml) ----
POSTGRES_USER=cafepos
POSTGRES_PASSWORD=cafepos
POSTGRES_DB=cafepos
# Host port for the Postgres container. Override if 5432 is already in use,
# then update the port in DATABASE_URL below to match.
POSTGRES_PORT=5432

# ---- Backend (apps/api) ----
PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://cafepos:cafepos@localhost:5432/cafepos?schema=public

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

CORS_ORIGINS=http://localhost:5173

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=change-me
MAIL_FROM="Cafe POS <noreply@example.com>"

# ---- Frontend (apps/web, Vite — only VITE_* vars are exposed to the client) ----
VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
